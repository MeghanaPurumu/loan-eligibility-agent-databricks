ENABLE_RAG=True
ENABLE_AUDIT=True
DATABASE_URL=main.loan_eligibility.loan_assessment_logs
RULES_PATH=data/loan_rules.json
POLICY_PDF_PATH=data/loan_policy.pdf
FAISS_INDEX_PATH=data/faiss_index
