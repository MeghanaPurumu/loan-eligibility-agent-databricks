# Production environment configurations for Databricks
MODE=prod
MODEL_PROVIDER=databricks
DATABRICKS_HOST=https://adb-xxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi_placeholder_token
DATABRICKS_SERVING_ENDPOINT=databricks-meta-llama-3-1-70b-instruct
USE_DATABRICKS=True
VECTOR_BACKEND=databricks
DATABRICKS_VECTOR_INDEX=main.loan_eligibility.loan_policy_index
